POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=ChatAppDb

JWT_SECRET=replace_with_minimum_32_characters_secret
JWT_ISSUER=chatapp
JWT_AUDIENCE=chatapp-users
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_HOURS=24

# Use your public IP first, then switch to your domain when attached.
# Examples:
# ALLOWED_FRONTEND_ORIGIN=http://3.92.10.14
# ALLOWED_FRONTEND_ORIGIN=https://chat.yourdomain.com
ALLOWED_FRONTEND_ORIGIN=http://YOUR_EC2_PUBLIC_IP
